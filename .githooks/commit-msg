#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:?commit message file is required}"
ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
STAGED_PATHS_JSON="$(
  git diff --cached --name-only --diff-filter=ACMR \
    | bash "${ROOT_DIR}/scripts/run-python.sh" -c \
      "import json,sys; print(json.dumps([line.strip() for line in sys.stdin if line.strip()]))"
)"
bash "${ROOT_DIR}/scripts/run-python.sh" "${ROOT_DIR}/.githooks/conventional_emoji.py" \
  --validate \
  --require-emoji \
  --require-issue-key \
  --branch "${CURRENT_BRANCH}" \
  --paths-json "${STAGED_PATHS_JSON}" \
  "${MSG_FILE}"
