#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
REMOTE="${1:-origin}"
PROTECTED_BRANCHES=("main" "develop" "master")

print_error() { echo "❌ $1" >&2; }
print_info() { echo "ℹ️ $1"; }
print_warn() { echo "⚠️ $1"; }

pushes_protected_branch="0"
while read -r local_ref _local_sha _remote_ref _remote_sha; do
  if [[ -z "${local_ref:-}" ]]; then
    continue
  fi
  if [[ "${local_ref}" == refs/heads/* ]]; then
    for protected_branch in "${PROTECTED_BRANCHES[@]}"; do
      if [[ "${local_ref}" == "refs/heads/${protected_branch}" ]]; then
        pushes_protected_branch="1"
      fi
    done
  fi
done

if [[ "${pushes_protected_branch}" == "1" ]]; then
  print_error "Push bloqueado para branch protegida (${PROTECTED_BRANCHES[*]}). Use Pull Request."
  exit 1
fi

if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
  PR_TITLE="$(gh pr list --head "${CURRENT_BRANCH}" --state open --limit 1 --json title --jq '.[0].title' 2>/dev/null || true)"
  if [[ -n "${PR_TITLE}" && "${PR_TITLE}" != "null" ]]; then
    print_info "Validando titulo do PR aberto da branch atual..."
    bash "${ROOT_DIR}/scripts/run-python.sh" "${ROOT_DIR}/.githooks/ci/validate_message.py" "${PR_TITLE}" --context "PR title" --branch "${CURRENT_BRANCH}"
  fi
else
  print_warn "gh nao autenticado; validacao local de PR title ignorada."
fi

COMMIT_PAYLOAD_JSON="$(
  bash "${ROOT_DIR}/scripts/run-python.sh" "${ROOT_DIR}/scripts/git-commit-subjects.py" \
    --repo-root "${ROOT_DIR}" \
    --remote "${REMOTE}" \
    --include-files
)"
if [[ "${COMMIT_PAYLOAD_JSON}" == "[]" ]]; then
  print_info "Nenhum commit exclusivo para validar no remoto ${REMOTE}."
  exit 0
fi

CHANGED_PATHS_JSON="$(
  printf '%s' "${COMMIT_PAYLOAD_JSON}" \
    | bash "${ROOT_DIR}/scripts/run-python.sh" -c \
      "import json,sys; payload=json.load(sys.stdin); seen=[]; \
[seen.append(path) for entry in payload for path in entry.get('paths', []) if path not in seen]; \
print(json.dumps(seen))"
)"

if ! bash "${ROOT_DIR}/scripts/run-python.sh" "${ROOT_DIR}/.githooks/conventional_emoji.py" --validate-branch "${CURRENT_BRANCH}" --paths-json "${CHANGED_PATHS_JSON}"; then
  print_error "Nome de branch invalido: ${CURRENT_BRANCH}"
  exit 1
fi

print_info "Validando subjects dos commits exclusivos ainda nao presentes em ${REMOTE}..."
bash "${ROOT_DIR}/scripts/run-python.sh" "${ROOT_DIR}/.githooks/conventional_emoji.py" --validate-many-json "${COMMIT_PAYLOAD_JSON}" --require-emoji --require-issue-key --branch "${CURRENT_BRANCH}"
