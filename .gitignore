# when .gitignore not ignoring files may be cache
# problem. Run this command to fix it
# $ git rm -r --cached .

*.history
desktop.ini
!app/df/**/desktop.ini
*.pyc
__pycache__/
.cache/
.venv/

# local runtime secrets
.env
.env.*
!.env.example
!.env.local.tpl
!/app/bootstrap/secrets/.env.local.tpl
app/bootstrap/user-config.yaml
app/df/git/.gitconfig.local
config/ai/*.local.yaml
!config/ai/*.local.yaml.tpl

# sensitive key/certificate material
*.pem
*.p12
*.pfx
*.key
!*.pub
!*.sops.yaml

# machine-local SSH runtime and overlays
app/df/ssh/sockets/
app/df/ssh/known_hosts
app/df/ssh/known_hosts.old
app/df/ssh/config.local

# machine-local secret material
app/df/secrets/dotfiles.age.local.key

# VS Code runtime state generated under app/df/vscode when linked into Code/User
app/df/vscode/globalStorage/
app/df/vscode/History/
app/df/vscode/workspaceStorage/
app/df/vscode/sync/

# local AI runtime state
.gemini/
.codex/*
!.codex/README.md
