# when .gitignore not ignoring files may be cache
# problem. Run this command to fix it
# $ git rm -r --cached .

*.history
desktop.ini
!df/**/desktop.ini
*.pyc
__pycache__/
.cache/
.venv/

# local runtime secrets
.env
.env.*
!.env.example
!.env.local.tpl
!/bootstrap/secrets/.env.local.tpl
bootstrap/user-config.yaml
df/git/.gitconfig.local

# sensitive key/certificate material
*.pem
*.p12
*.pfx
*.key
!*.pub
!*.sops.yaml

# machine-local SSH runtime and overlays
df/ssh/sockets/
df/ssh/known_hosts
df/ssh/known_hosts.old
df/ssh/config.local

# machine-local secret material
df/secrets/dotfiles.age.local.key

# VS Code runtime state generated under df/vscode when linked into Code/User
df/vscode/globalStorage/
df/vscode/History/
df/vscode/workspaceStorage/
df/vscode/sync/

# local AI runtime state
.gemini/
.codex/*
!.codex/README.md
