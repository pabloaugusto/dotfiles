name: Docker Image CI

on:
  push:
    branches: ["**"]
  pull_request:
    branches: [master]

jobs:
  build:
    name: lint
    runs-on: "ubuntu-latest"

    steps:
      - name: Install Act dependencies
        if: ${{ env.ACT }}
        run: |

      - uses: actions/checkout@v4
      - name: Build the Docker image
        run: docker build . --file Dockerfile
