# [user]
# 	name = Seu Nome
# 	email = you@example.com
# 	username = your-github-user


#[github]
#	user = your-github-user
#	token = <redacted>


[init]
	defaultBranch = main


# Os aliases Git versionados ficam centralizados em ~/.config/git/.gitconfig-base.

[pull]
	rebase = false
	ff = only

[push]
	autoSetupRemote = true
	default = matching # https://git-scm.com/docs/git-config#git-config-pushdefault

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[pretty]
	nice = "%C(blue bold)%h %C(yellow)%cd %C(white)| %C(green)%s%C(red)%d %C(yellow)[%an]%Creset"

[web]
	browser = google-chrome

[core]
	#excludesfile = ~/.gitignore #global .gitignore file
	#ignorecase = true

	# Treat spaces before tabs and all kinds of trailing whitespace as an error
	# [default] trailing-space: looks for spaces at the end of a line
	# [default] space-before-tab: looks for spaces before tabs at the beginning of a line
	whitespace = space-before-tab,-indent-with-non-tab,trailing-space

	# Speed up commands involving untracked files such as `git status`.
	# https://git-scm.com/docs/git-update-index#_untracked_cache
	untrackedCache = true
	# Make `git rebase` safer on OS X
	# More info: <http://www.git-tower.com/blog/make-git-rebase-safe-on-osx/>
	trustctime = false

	autocrlf = false

[color]
	# Use colors in Git commands that are capable of colored output when
	# outputting to the terminal. (This is the default setting in Git ≥ 1.8.4.)
	ui = always
	status = auto
    branch = auto
    interactive = auto
	diff = auto

[help]
	# Automatically correct and execute mistyped commands
	autocorrect = 1
	#log = true


[url "git@github.com:"]

	insteadOf = "gh:"
	pushInsteadOf = "github:"
	pushInsteadOf = "git://github.com/"

[url "git://github.com/"]

	insteadOf = "github:"

[url "git@gist.github.com:"]

	insteadOf = "gst:"
	pushInsteadOf = "gist:"
	pushInsteadOf = "git://gist.github.com/"

[url "git://gist.github.com/"]

	insteadOf = "gist:"





[safe] # desliga a proteção de “dubious ownership” para qualquer repo
	directory = *
##############################################################################################
# Carrega configurações do Git por "ambiente" (na prática: pelo caminho do repositório)
# OBS: includeIf usa o caminho do diretório .git (gitdir). Não detecta SO/WSL/container diretamente.
##############################################################################################

# Base (carregado em qualquer contexto)
# -----------------------------------------------------------
[include]
    path = ~/.config/git/.gitconfig-base
[include]
    path = ~/.config/git/.gitconfig.local

# Overlays por worktree (ex.: signer tecnico de automacao) devem usar
# `config.worktree` via tasks git:signing:*.


# Windows host (Git rodando no Windows)
# Use gitdir/i para tratar paths como case-insensitive
# -----------------------------------------------------------
[includeIf "gitdir/i:C:/"]
    path = ~/.config/git/.gitconfig-windows
[includeIf "gitdir/i:D:/"]
    path = ~/.config/git/.gitconfig-windows


# WSL (Git rodando no WSL acessando repos no filesystem do Windows)
# Exemplos: /mnt/c/... e /mnt/d/...
# -----------------------------------------------------------
[includeIf "gitdir:/mnt/c/"]
    path = ~/.config/git/.gitconfig-wsl-windowsfs
[includeIf "gitdir:/mnt/d/"]
    path = ~/.config/git/.gitconfig-wsl-windowsfs


# Linux (host Linux) OU WSL (repos no filesystem Linux)
# OBS: se o repo está em /home/, o Git não diferencia Linux host vs WSL.
# -----------------------------------------------------------
[includeIf "gitdir:/home/"]
    path = ~/.config/git/.gitconfig-linux


# macOS (se aplicável)
# -----------------------------------------------------------
[includeIf "gitdir:/Users/"]
    path = ~/.config/git/.gitconfig-mac


# Devcontainer (qualquer host)
# Aplica para:
#   /workspaces/<repo>/  (padrão VS Code)
#   /workspace/<repo>/   (algumas imagens/ambientes)
# -----------------------------------------------------------
[includeIf "gitdir:/workspaces/"]
    path = ~/.config/git/.gitconfig-devcontainer
[includeIf "gitdir:/workspace/"]
    path = ~/.config/git/.gitconfig-devcontainer


# Devcontainer por host (opcional)
# Só funciona se o workspace dentro do container tiver paths diferentes por host, ex.:
#   /workspaces-win/<repo>/, /workspaces-wsl/<repo>/, /workspaces-linux/<repo>/
# -----------------------------------------------------------
[includeIf "gitdir:/workspaces-win/"]
    path = ~/.config/git/.gitconfig-devcontainer-host-windows
[includeIf "gitdir:/workspaces-wsl/"]
    path = ~/.config/git/.gitconfig-devcontainer-host-wsl
[includeIf "gitdir:/workspaces-linux/"]
    path = ~/.config/git/.gitconfig-devcontainer-host-linux
[credential "https://github.com"]
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper = !gh auth git-credential
