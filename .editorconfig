# EditorConfig is awesome: http://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2
tab_width = 2


[*.{json}]
indent_size = 2
indent_style = space

[*.{ps1,psm1,psd1}]
indent_size = 4

[*.{ps1xml,props,xml,yaml}]
indent_size = 2


[{.,}*.{js{,*},y{a,}ml}]
indent_style = space
indent_size = 2
tab_width = 2
quote_type = single



[*.{md,txt}]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false
