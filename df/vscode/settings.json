{
	//Appearance Settings -----------------------------------------------------------
	"workbench.colorTheme": "GitHub Dark",
	"workbench.preferredDarkColorTheme": "GitHub Dark",
	"workbench.preferredHighContrastColorTheme": "GitHub Dark",
	"window.title": "${folderName} - ${activeEditorShort}",
	"window.commandCenter": true,
	"workbench.statusBar.visible": true,
	"workbench.activityBar.location": "left",
	//Appearance Settings Extensions-----------------------------------------------
	"indentRainbow.colorOnWhiteSpaceOnly": true,
	"indentRainbow.indicatorStyle": "light",
	//Editor Settings -------------------------------------------------------------
	"files.autoSave": "onFocusChange",
	"workbench.startupEditor": "none",
	"editor.lightbulb.experimental.showAiIcon": "on",
	"editor.fontFamily": "'ComicCode Nerd Font Mono', 'Hack Nerd Font Mono',  Consolas, 'Courier New', monospace",
	"editor.formatOnSave": true,
	"editor.minimap.enabled": false,
	"editor.stickyScroll.enabled": true,
	"editor.snippetSuggestions": "top",
	"editor.tabCompletion": "on",
	"editor.acceptSuggestionOnEnter": "smart",
	"editor.inlineSuggest.showToolbar": "always",
	"editor.linkedEditing": true,
	"editor.rulers": [
		100
	],
	//Terminal Settings -----------------------------------------------------------
	"terminal.integrated.defaultProfile.windows": "PowerShell",
	"terminal.external.windowsExec": "wt",
	"terminal.sourceControlRepositoriesKind": "external",
	"terminal.integrated.env.linux": {},
	"terminal.integrated.env.windows": {},
	"terminal.integrated.drawBoldTextInBrightColors": false,
	"terminal.integrated.enableImages": true,
	"terminal.integrated.shellIntegration.suggestEnabled": true,
	"terminal.integrated.tabs.focusMode": "singleClick",
	//Security Settings -----------------------------------------------------------
	"security.workspace.trust.untrustedFiles": "open",
	"security.workspace.trust.enabled": false,
	//Git Settings -----------------------------------------------------------
	"git.openRepositoryInParentFolders": "always",
	"scm.alwaysShowRepositories": true,
	//Telemetry Settings -----------------------------------------------------------
	"telemetry.telemetryLevel": "off",
	"gitlens.telemetry.enabled": false,
	"gitlens.statusBar.enabled": true,
	"gitlens.statusBar.alignment": "left",
	"gitlens.statusBar.reduceFlicker": true,
	"gitlens.statusBar.format": "${repo} | ${branch}${aheadBehind} | ${remote} | ${author}",
	"gitlens.currentLine.enabled": true,
	"gitlens.codeLens.enabled": true,
	"gitlens.hovers.enabled": true,
	"mdb.sendTelemetry": false,
	"intelephense.telemetry.enabled": null,
	"sonarlint.disableTelemetry": true,
	"dotnetAcquisitionExtension.enableTelemetry": false,
	"redhat.telemetry.enabled": false,
	//Powershell Settings -----------------------------------------------------------
	"powershell.startAsLoginShell.linux": true,
	"powershell.enableProfileLoading": true,
	"powershell.codeFormatting.autoCorrectAliases": true,
	"security.allowedUNCHosts": [
		"wsl.localhost",
		"10.0.0.5",
		"OMV",
		"10.0.0.10",
		"TRUENAS",
	],
	//File Associations Settings -----------------------------------------------------------
	"files.associations": {
		"*.razor": "csharp",
		"*.yml": "yaml",
		"*.tom": "toml",
	},
	//Project Manager Settings -----------------------------------------------------------
	"projectManager.git.baseFolders": [
		"~\\projects",
		"~\\clients\\cr\\projects"
	],
