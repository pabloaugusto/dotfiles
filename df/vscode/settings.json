		},
		"[]": {
			"foreground": "#00aeda",
			"background": "#00aeda",
			"icon": "circle",
			"opacity": 20,
		},
		"note": {
			"foreground": "#0088aa",
			"background": "#00aeda",
			"opacity": 20,
			"icon": "note",
		},
		"qa": {
			"foreground": "#74e3ff",
			"background": "#00aeda",
			"iconColour": "#00aeda",
			"opacity": 60,
			"icon": "eye",
		},
		"comment": {
			"icon": "comment-discussion",
		},
		"bookmark": {
			"foreground": "#0088aa",
			"background": "#00aeda",
			"opacity": 20,
			"icon": "bookmark",
		},
