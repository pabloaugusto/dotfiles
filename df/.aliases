###############################################################################
# df/.aliases
#
# Fonte canonica de aliases e funcoes para shells Unix deste repositorio.
# Bash e Zsh devem carregar este arquivo em vez de espalhar aliases nos loaders.
#
# Objetivos:
# - concentrar atalhos operacionais em um unico ponto
# - manter paridade conceitual com df/powershell/aliases.ps1
# - deixar .bashrc e .zshrc focados em bootstrap do shell
###############################################################################

###############################################################################
# Compatibilidade e comandos base
###############################################################################

alias ag='antigravity'
alias c='clear'
alias g='git'
alias pn='pnpm'

if command -v ssh.exe >/dev/null 2>&1; then
	alias ssh='ssh.exe'
fi

if command -v ssh-add.exe >/dev/null 2>&1; then
	alias ssh-add='ssh-add.exe'
fi

if ! command -v op-ssh-sign >/dev/null 2>&1 && command -v op-ssh-sign-wsl.exe >/dev/null 2>&1; then
	alias op-ssh-sign='op-ssh-sign-wsl.exe'
fi

###############################################################################
# Listagem, descoberta e utilitarios gerais
###############################################################################

if command -v dircolors >/dev/null 2>&1; then
	if [ -r "$HOME/.dircolors" ]; then
		eval "$(dircolors -b "$HOME/.dircolors")"
	else
		eval "$(dircolors -b)"
	fi
fi

alias ls='ls --color=auto'
alias ll='ls -alF --group-directories-first'
alias la='ls -A'
alias l='ls -CF'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'

alias iof='dig +short txt istheinternetonfire.com | fmt'
alias update='sudo apt update && sudo apt upgrade --yes'
alias drop_cache='sudo sh -c "echo 3 >'\''/proc/sys/vm/drop_caches'\'' && swapoff -a && swapon -a && printf '\''\n%s\n'\'' '\''Ram-cache and Swap Cleared'\''"'
alias 755d='find . -type d -exec chmod 755 {} \;'
alias 644f='find . -type f -exec chmod 644 {} \;'
alias ymp3='youtube-dl --extract-audio --audio-format mp3'

###############################################################################
# Navegacao rapida
###############################################################################

alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias h='cd "$HOME"'
alias p='cd "${PROJECTS:-$HOME/projects}"'
alias d='cd "${DOTFILES:-$HOME/dotfiles}"'
alias o='cd "${HOME_OPS:-$HOME/projects/home-ops}"'
alias ho='cd "${HOME_OPS:-$HOME/projects/home-ops}"'
alias kk='cd "${HOME_OPS:-$HOME/projects/home-ops}"'
alias cr='cd "${CLIENTS:-$HOME/clients}/cr"'
alias crn='cd "${CLIENTS:-$HOME/clients}/cr/projects/cr_net"'
alias crw='cd "${CLIENTS:-$HOME/clients}/cr/projects/cr_net/cr.web"'

###############################################################################
# Operacao do proprio repo de dotfiles
###############################################################################

df() {
	local repo_root
	repo_root="${DOTFILES:-$HOME/dotfiles}"
	git --git-dir="$repo_root/.git" --work-tree="$repo_root" "$@"
}

dpull() {
	local repo_root
	repo_root="${DOTFILES:-$HOME/dotfiles}"
	cd "$repo_root" || return 1
	git pull
	cd - >/dev/null || true
}

dpush() {
	local repo_root
	repo_root="${DOTFILES:-$HOME/dotfiles}"
	cd "$repo_root" || return 1
	git acp "Dotfiles Update"
	cd - >/dev/null || true
}

dfsync() {
	local repo_root
	repo_root="${DOTFILES:-$HOME/dotfiles}"
	cd "$repo_root" || return 1
	git fetch --prune origin && git pull --ff-only
	cd - >/dev/null || true
}

###############################################################################
# Infra e GitOps
###############################################################################

t() {
	terraform "$@"
}

a() {
	ansible "$@"
}

f() {
	flux "$@"
}

fs() {
	flux get all -A --status-selector ready=false "$@"
}

k() {
	kubectl "$@"
}

# kubectl get
kg() { k get "$@"; }
kgp() { k get pods "$@"; }
kgpa() { k get pods -A "$@"; }
kgpn() { k get pods -n "$@"; }
kgs() { k get services "$@"; }
kgsa() { k get services -A "$@"; }
kgsn() { k get services -n "$@"; }
kgi() { k get ingress "$@"; }
kgia() { k get ingress -A "$@"; }
kgin() { k get ingress -n "$@"; }
kgh() { k get helmreleases "$@"; }
kgha() { k get helmreleases -A "$@"; }
kghn() { k get helmreleases -n "$@"; }
kgk() { k get kustomizations "$@"; }
kgka() { k get kustomizations -A "$@"; }
kgkn() { k get kustomizations -n "$@"; }
kgd() { k get deployments "$@"; }
kgda() { k get deployments -A "$@"; }
kgdn() { k get deployments -n "$@"; }
kgns() { k get namespaces "$@"; }
kgnsa() { k get namespaces -A "$@"; }
kgnsn() { k get namespaces -n "$@"; }
kgsec() { k get secrets "$@"; }
kgseca() { k get secrets -A "$@"; }
kgsecn() { k get secrets -n "$@"; }
kgcj() { k get cronjobs "$@"; }
kgcja() { k get cronjobs -A "$@"; }
kgcjn() { k get cronjobs -n "$@"; }
kgcm() { k get configmaps "$@"; }
kgcma() { k get configmaps -A "$@"; }
kgcmn() { k get configmaps -n "$@"; }
kgj() { k get jobs "$@"; }
kgja() { k get jobs -A "$@"; }
kgjn() { k get jobs -n "$@"; }
kgn() { kubectl get nodes "$@"; }
kgnw() { kubectl get nodes -o wide "$@"; }

# kubectl describe
kd() { k describe "$@"; }
kdp() { k describe pods "$@"; }
kdpa() { k describe pods -A "$@"; }
kdpn() { k describe pods -n "$@"; }
kds() { k describe services "$@"; }
kdsa() { k describe services -A "$@"; }
kdsn() { k describe services -n "$@"; }
kdi() { k describe ingress "$@"; }
kdia() { k describe ingress -A "$@"; }
kdin() { k describe ingress -n "$@"; }
kdh() { k describe helmrelease "$@"; }
kdha() { k describe helmrelease -A "$@"; }
kdhn() { k describe helmrelease -n "$@"; }
kdk() { k describe kustomizations "$@"; }
kdka() { k describe kustomizations -A "$@"; }
kdkn() { k describe kustomizations -n "$@"; }
kdd() { k describe deployment "$@"; }
kdda() { k describe deployment -A "$@"; }
kddn() { k describe deployment -n "$@"; }
kdns() { k describe namespaces "$@"; }
kdnsa() { k describe namespaces -A "$@"; }
kdnsn() { k describe namespaces -n "$@"; }
kdsec() { k describe secret "$@"; }
kdseca() { k describe secret -A "$@"; }
kdsecn() { k describe secret -n "$@"; }
kdcj() { k describe cronjobs "$@"; }
kdcja() { k describe cronjob -A "$@"; }
kdcjn() { k describe cronjob -n "$@"; }
kdcm() { k describe configmaps "$@"; }
kdcma() { k describe configmap -A "$@"; }
kdcmn() { k describe configmap -n "$@"; }
kdj() { k describe jobs "$@"; }
kdja() { k describe jobs -A "$@"; }
kdjn() { k describe jobs -n "$@"; }

# kubectl logs e execucao
kl() { k logs "$@"; }
kln() { k logs -n "$@"; }
kexec() { kubectl exec -it "$@"; }
kbash() { kubectl exec -it "$@" -- /bin/bash; }
kapir() { kubectl api-resources "$@"; }
kapiv() { kubectl api-versions "$@"; }
kconf() { kubectl config "$@"; }
kconfv() { kubectl config view "$@"; }
kusers() { kubectl config view -o jsonpath='{.users[*].name}' "$@"; }
kcontext() { kubectl config get-contexts "$@"; }
