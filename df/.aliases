alias c='clear'
alias g=git

# git for dotfiles
alias df='git --git-dir="$HOME/dotfiles/.git" --work-tree="$HOME/dotfiles"'

# ssh tools aliases for Linux WSL running on Windows 11
alias ssh=ssh.exe
alias ssh-add=ssh-add.exe

# ls tools
alias ll='ls -alF --group-directories-first'
alias la='ls -A'
alias l='ls -CF'

# dev
alias pn=pnpm

# fast dirs swap
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias h='cd $HOME'
alias p='cd $PROJECTS'
alias d='cd $DOTFILES'
alias cr='cd $CLIENTS/cr'
alias crn='cd $CLIENTS/cr/projects/cr_net'
alias crw='cd $CLIENTS/cr/projects/cr_net/cr.web'



#alias reload=". ~/.profile"

# Is the internet on fire?
alias iof='dig +short txt istheinternetonfire.com | fmt'

# Update and upgrade
alias update='sudo apt update && sudo apt upgrade --yes'

# Connect and disconnect Sonos speaker
# alias btcon='bluetoothctl <<< "connect 5C:AA:FD:D4:EB:84"'
# alias btuncon='bluetoothctl <<< disconnect'

# push updates at dotfiles to github
function dpush {
	cd ~/dotfiles           # go to dotfiles path
	g acp "Dotfiles Update" #git add all & commit with message "updated" & push
	cd - >/dev/null         #back to previous patjh
}

# pull updates at dotfiles from github
function dpull {
	cd ~/dotfiles # go to dotfiles path
	g pull
	cd - >/dev/null #back to previous patjh
}

# sync local WSL dotfiles with remote using safe fast-forward policy
function dfsync {
	cd ~/dotfiles || return 1
	git fetch --prune origin && git pull --ff-only
	cd - >/dev/null || true
}

