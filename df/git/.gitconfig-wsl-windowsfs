################################################################################
# WSL usando repositórios no filesystem do Windows (/mnt/c, /mnt/d, etc.)
# - Assinatura 1Password (program WSL)
################################################################################

[core]
    # Se você usa VS Code + Remote WSL, isso funciona.
    # Alternativas: vim | nano
    editor = code --wait

    # Em /mnt/* normalmente é melhor:
    filemode = false
    ignorecase = true
    # Disable fsmonitor in WSL to avoid noisy "Empty last update token".
    fsmonitor = false


################################################################################
# Assinatura via SSH (1Password) - WSL (Windows host)
################################################################################

# [user]
#     # signingkey = KEY ESPECIFICA DO AMBIENTE
#     # (por padrão vem do ~/.gitconfig-base)
#     # signingkey = ssh-ed25519 AAAA...

[gpg "ssh"]
    # Program from PATH (wrapper maps to op-ssh-sign-wsl.exe in WSL bootstrap).
    program = op-ssh-sign

[commit]
    # gpgsign = VALOR ESPECIFICO DO AMBIENTE
    gpgsign = true
